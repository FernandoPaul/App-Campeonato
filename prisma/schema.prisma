generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Status {
  DRAFT
  PUBLISHED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

enum Role {
  ADMIN
  EDITOR
}

enum EventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  DOUBLE_YELLOW
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  sport     String
  logoUrl   String?
  status    Status     @default(DRAFT)
  teams     Team[]
  matches   Match[]
  standings Standing[]
  players   Player[]
  createdAt DateTime   @default(now())
}

model Team {
  id          String       @id @default(uuid())
  categoryId  String
  name        String
  slug        String       @unique
  logoUrl     String?
  city        String?
  status      Status       @default(DRAFT)
  category    Category     @relation(fields: [categoryId], references: [id])
  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")
  standings   Standing[]
  players     Player[]
  matchEvents MatchEvent[]
  createdAt   DateTime     @default(now())
}

model Player {
  id          String       @id @default(uuid())
  teamId      String
  categoryId  String
  firstName   String
  lastName    String
  dorsal      Int
  status      Status       @default(PUBLISHED)
  team        Team         @relation(fields: [teamId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  matchEvents MatchEvent[]
  createdAt   DateTime     @default(now())

  @@unique([teamId, dorsal])
}

model Match {
  id            String       @id @default(uuid())
  categoryId    String
  homeTeamId    String
  awayTeamId    String
  homeScore     Int?
  awayScore     Int?
  matchDate     DateTime?
  round         String?
  matchStatus   MatchStatus  @default(SCHEDULED)
  status        Status       @default(DRAFT)
  category      Category     @relation(fields: [categoryId], references: [id])
  homeTeam      Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  events        MatchEvent[]
  createdAt     DateTime     @default(now())
  forfeit       Boolean      @default(false)
  forfeitReason String?
  forfeitTeamId String?
}

model MatchEvent {
  id        String    @id @default(uuid())
  matchId   String
  playerId  String
  teamId    String
  type      EventType
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player    @relation(fields: [playerId], references: [id])
  team      Team      @relation(fields: [teamId], references: [id])
  createdAt DateTime  @default(now())
}

model Standing {
  id           String   @id @default(uuid())
  categoryId   String
  teamId       String
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  category     Category @relation(fields: [categoryId], references: [id])
  team         Team     @relation(fields: [teamId], references: [id])
  updatedAt    DateTime @updatedAt

  @@unique([categoryId, teamId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
}
